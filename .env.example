# 可选：启用文档云端同步（Supabase）
# 创建项目后从 Dashboard → Settings → API 复制
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# 管理员账号（用于编辑权限与查看者只读拉取）
# 在 Authentication → Users 中创建该邮箱用户，复制其 UUID 填入下方；密码需与下方一致
VITE_SUPABASE_ADMIN_EMAIL=admin@allround.local
VITE_SUPABASE_ADMIN_UID=管理员用户的UUID
# 管理员密码（默认 root），需与 Supabase 中该用户的密码完全一致
# VITE_SUPABASE_ADMIN_PASSWORD=root
