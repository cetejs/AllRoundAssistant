# 可选：启用文档云端同步（Supabase）
# 创建项目后从 Dashboard → Settings → API 复制
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# 管理员登录：仅需配置密码，输入与下方一致即登录成功（默认 root）
VITE_SUPABASE_ADMIN_PASSWORD=root
# 以下为云端拉取/同步用（可选）：查看者拉取与管理员同步需管理员 UUID；若需同步云端再配置邮箱并在 Supabase 创建对应用户
# VITE_SUPABASE_ADMIN_EMAIL=admin@allround.local
# VITE_SUPABASE_ADMIN_UID=管理员用户的UUID
